@page "/user"
@rendermode InteractiveServer
@inject HttpClient Http
@inject NavigationManager Navigation
@inject Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage.ProtectedSessionStorage SessionStorage

<PageTitle>Shiftly – Profiel</PageTitle>

@if (!_sessionChecked) { }
else if (!_isLoggedIn) { }
else if (_isLoading)
{
    <div class="dash-root">
        <p class="loading-text">Laden…</p>
    </div>
}
else
{
    <div class="dash-root">
        <header class="topbar">
            <div class="brand">
                <img src="/ShiftlyLogo.png" class="brand-logo" alt="Shiftly logo" />
            </div>
            <nav class="nav-pill">
                <a class="nav-item" href="/dashboard">Dashboard</a>
                <a class="nav-item" href="/shifts">Shifts</a>
                <a class="nav-item" href="/wishlist">Wishlist</a>
                <a class="nav-item" href="/abonnementen">Abonnementen</a>
            </nav>
            <div class="top-actions">
                <a class="btn-ghost" href="/user">@_fullName</a>
            </div>
        </header>

        <main class="profile-page">
            <section class="profile-card">
                @if (!string.IsNullOrWhiteSpace(_profileMessage))
                {
                    <div class="message success">@_profileMessage</div>
                }
                @if (!string.IsNullOrWhiteSpace(_profileError))
                {
                    <div class="message error">@_profileError</div>
                }

                <EditForm Model="_userModel" OnValidSubmit="SaveProfile">
                    <div class="section-header header-row">
                        <div>
                            <h1>Mijn profiel</h1>
                            <p>Beheer hier je accountgegevens.</p>
                        </div>
                        <div class="header-actions">
                            @if (!_isEditingProfile)
                            {
                                <button type="button" class="primary-btn" @onclick="StartEditProfile">Bewerk profiel</button>
                            }
                            else
                            {
                                <button type="button" class="secondary-btn" @onclick="CancelEditProfile">Annuleren</button>
                                <button type="submit" class="primary-btn">Opslaan</button>
                            }
                        </div>
                    </div>

                    <div class="form-grid">
                        <div class="field">
                            <label for="firstName">Voornaam</label>
                            <input id="firstName" @bind="_userModel.FirstName" disabled="@(!_isEditingProfile)" />
                        </div>
                        <div class="field">
                            <label for="lastName">Achternaam</label>
                            <input id="lastName" @bind="_userModel.LastName" disabled="@(!_isEditingProfile)" />
                        </div>
                        <div class="field full-width">
                            <label for="email">E-mail</label>
                            <input id="email" @bind="_userModel.Email" disabled="@(!_isEditingProfile)" />
                        </div>
                        <div class="field full-width checkbox-field">
                            <label>Studentenstatus</label>
                            <div class="checkbox-box">
                                <label class="checkbox-label">
                                    <input type="checkbox" @bind="_userModel.IsStudent" disabled="@(!_isEditingProfile)" />
                                    <span>Ik ben student</span>
                                </label>
                            </div>
                        </div>
                    </div>
                </EditForm>
            </section>

            <section class="profile-card">
                @if (!string.IsNullOrWhiteSpace(_passwordMessage))
                {
                    <div class="message success">@_passwordMessage</div>
                }
                @if (!string.IsNullOrWhiteSpace(_passwordError))
                {
                    <div class="message error">@_passwordError</div>
                }

                <div class="section-header header-row">
                    <div>
                        <h2>Wachtwoord</h2>
                        <p>Wijzig hier je wachtwoord.</p>
                    </div>
                    <div class="header-actions">
                        @if (!_showPasswordForm)
                        {
                            <button type="button" class="primary-btn" @onclick="OpenPasswordForm">Wijzig wachtwoord</button>
                        }
                    </div>
                </div>

                @if (_showPasswordForm)
                {
                    <EditForm Model="_passwordModel" OnValidSubmit="ChangePassword">
                        <div class="form-grid">
                            <div class="field">
                                <label for="currentPassword">Huidig wachtwoord</label>
                                <input id="currentPassword" type="password" @bind="_passwordModel.CurrentPassword" />
                            </div>
                            <div class="field">
                                <label for="newPassword">Nieuw wachtwoord</label>
                                <input id="newPassword" type="password" @bind="_passwordModel.NewPassword" />
                            </div>
                            <div class="field full-width">
                                <label for="confirmPassword">Bevestig nieuw wachtwoord</label>
                                <input id="confirmPassword" type="password" @bind="_passwordModel.ConfirmPassword" />
                            </div>
                        </div>

                        <div class="button-row">
                            <button type="button" class="secondary-btn" @onclick="CancelPasswordForm">Annuleren</button>
                            <button type="submit" class="primary-btn">Opslaan</button>
                        </div>
                    </EditForm>
                }
            </section>

            <section class="profile-card">
                <button type="button" class="danger-btn" @onclick="Logout">Uitloggen</button>
            </section>
        </main>
    </div>
}

@code {
    private bool _sessionChecked = false;
    private bool _isLoggedIn = false;
    private bool _isLoading = true;
    private bool _isEditingProfile = false;
    private bool _showPasswordForm = false;

    int _userId;
    string _fullName = "";
    string _profileMessage = "";
    string _profileError = "";
    string _passwordMessage = "";
    string _passwordError = "";

    UserProfileModel _userModel = new();
    UserProfileModel _originalUserModel = new();
    ChangePasswordModel _passwordModel = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        try
        {
            var idResult = await SessionStorage.GetAsync<int>("userId");
            var nameResult = await SessionStorage.GetAsync<string>("userFullName");

            if (idResult.Success && idResult.Value > 0)
            {
                _userId = idResult.Value;
                _fullName = nameResult.Success ? nameResult.Value ?? "" : "";
                _isLoggedIn = true;
                _sessionChecked = true;
                await LoadUserData();
            }
            else
            {
                _isLoggedIn = false;
                _sessionChecked = true;
                StateHasChanged();
                Navigation.NavigateTo("/", forceLoad: false);
            }
        }
        catch
        {
            _isLoggedIn = false;
            _sessionChecked = true;
            Navigation.NavigateTo("/", forceLoad: false);
        }
    }

    async Task LoadUserData()
    {
        _isLoading = true;
        _profileMessage = "";
        _profileError = "";
        StateHasChanged();

        try
        {
            var user = await Http.GetFromJsonAsync<UserProfileModel>($"GetUserById?id={_userId}");

            if (user is not null)
            {
                _userModel = user;
                _fullName = $"{_userModel.FirstName} {_userModel.LastName}".Trim();
                _originalUserModel = new UserProfileModel
                {
                    FirstName = _userModel.FirstName,
                    LastName = _userModel.LastName,
                    Email = _userModel.Email,
                    IsStudent = _userModel.IsStudent
                };
            }
        }
        catch
        {
            _profileError = "Profielgegevens konden niet geladen worden.";
        }

        _isLoading = false;
        StateHasChanged();
    }

    void StartEditProfile()
    {
        _profileMessage = "";
        _profileError = "";
        _originalUserModel = new UserProfileModel
        {
            FirstName = _userModel.FirstName,
            LastName = _userModel.LastName,
            Email = _userModel.Email,
            IsStudent = _userModel.IsStudent
        };
        _isEditingProfile = true;
    }

    void CancelEditProfile()
    {
        _profileMessage = "";
        _profileError = "";
        _userModel = new UserProfileModel
        {
            FirstName = _originalUserModel.FirstName,
            LastName = _originalUserModel.LastName,
            Email = _originalUserModel.Email,
            IsStudent = _originalUserModel.IsStudent
        };
        _isEditingProfile = false;
    }

    async Task SaveProfile()
    {
        _profileMessage = "";
        _profileError = "";

        try
        {
            var payload = new
            {
                name = _userModel.LastName,
                firstName = _userModel.FirstName,
                email = _userModel.Email,
                isStudent = _userModel.IsStudent
            };

            var response = await Http.PutAsJsonAsync($"UpdateUser?id={_userId}", payload);

            if (response.IsSuccessStatusCode)
            {
                _fullName = $"{_userModel.FirstName} {_userModel.LastName}".Trim();
                await SessionStorage.SetAsync("userFullName", _fullName);
                _originalUserModel = new UserProfileModel
                {
                    FirstName = _userModel.FirstName,
                    LastName = _userModel.LastName,
                    Email = _userModel.Email,
                    IsStudent = _userModel.IsStudent
                };
                _isEditingProfile = false;
                _profileMessage = "Profiel succesvol opgeslagen.";
            }
            else
            {
                _profileError = "Profiel opslaan is mislukt.";
            }
        }
        catch
        {
            _profileError = "Er ging iets mis bij het opslaan van je profiel.";
        }
    }

    void OpenPasswordForm()
    {
        _passwordMessage = "";
        _passwordError = "";
        _showPasswordForm = true;
    }

    void CancelPasswordForm()
    {
        _passwordMessage = "";
        _passwordError = "";
        _showPasswordForm = false;
        _passwordModel = new ChangePasswordModel();
    }

    async Task ChangePassword()
    {
        _passwordMessage = "";
        _passwordError = "";

        if (string.IsNullOrWhiteSpace(_passwordModel.CurrentPassword) ||
            string.IsNullOrWhiteSpace(_passwordModel.NewPassword) ||
            string.IsNullOrWhiteSpace(_passwordModel.ConfirmPassword))
        {
            _passwordError = "Vul alle wachtwoordvelden in.";
            return;
        }

        if (_passwordModel.NewPassword != _passwordModel.ConfirmPassword)
        {
            _passwordError = "Nieuw wachtwoord en bevestiging zijn niet hetzelfde.";
            return;
        }

        try
        {
            var currentPassword = Uri.EscapeDataString(_passwordModel.CurrentPassword);
            var newPassword = Uri.EscapeDataString(_passwordModel.NewPassword);

            var response = await Http.PutAsync($"ChangePassword?userId={_userId}&currentPassword={currentPassword}&newPassword={newPassword}", null);

            if (response.IsSuccessStatusCode)
            {
                _passwordMessage = "Wachtwoord succesvol gewijzigd.";
                _showPasswordForm = false;
                _passwordModel = new ChangePasswordModel();
            }
            else
            {
                var errorText = await response.Content.ReadAsStringAsync();

                if (!string.IsNullOrWhiteSpace(errorText) && errorText.Contains("Huidig wachtwoord is onjuist"))
                    _passwordError = "Huidig wachtwoord is onjuist.";
                else
                    _passwordError = "Wachtwoord wijzigen is mislukt.";
            }
        }
        catch
        {
            _passwordError = "Er ging iets mis bij het wijzigen van je wachtwoord.";
        }
    }

    async Task Logout()
    {
        await SessionStorage.DeleteAsync("userId");
        await SessionStorage.DeleteAsync("userFullName");
        Navigation.NavigateTo("/", forceLoad: false);
    }

    class UserProfileModel
    {
        public string FirstName { get; set; } = "";
        public string LastName { get; set; } = "";
        public string Email { get; set; } = "";
        public bool IsStudent { get; set; }
    }

    class ChangePasswordModel
    {
        public string CurrentPassword { get; set; } = "";
        public string NewPassword { get; set; } = "";
        public string ConfirmPassword { get; set; } = "";
    }
}