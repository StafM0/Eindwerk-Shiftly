@page "/dashboard"
@rendermode InteractiveServer
@inject HttpClient Http
@inject NavigationManager Navigation
@inject Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage.ProtectedSessionStorage SessionStorage

<PageTitle>Shiftly – Dashboard</PageTitle>

@if (!_sessionChecked){}
else if (!_isLoggedIn){}
else if (_isLoading)
{
    <div class="dash-root">
        <p class="loading-text">Laden…</p>
    </div>
}
else
{
    <div class="dash-root">
        <header class="topbar">
            <div class="brand">
                <img src="/ShiftlyLogo.png" class="brand-logo" alt="Shiftly" />
            </div>
            <nav class="nav-pill">
                <a class="nav-item is-active" href="/dashboard">Dashboard</a>
                <a class="nav-item" href="/shifts">Shifts</a>
                <a class="nav-item" href="/wishlist">Wishlist</a>
                <a class="nav-item" href="/abonnementen">Abonnementen</a>
            </nav>
            <div class="top-actions">
                <a class="btn-ghost" href="/user">@_fullName</a>
            </div>
        </header>

        <main class="grid-layout">
            <section class="card">
                <div class="card-header">
                    <div>
                        <h2 class="card-title">Opkomende shifts</h2>
                        <p class="card-sub">Je komende dagen</p>
                    </div>
                    <a class="btn-primary-sm" href="/shift-form">+ Add</a>
                </div>
                <div class="item-list">
                    @if (_shifts.Count == 0)
                    {
                        <div class="item-row">
                            <div class="item-meta">Geen shifts gevonden.</div>
                        </div>
                    }
                    else
                    {
                        @foreach (var shift in _shifts)
                        {
                            <div class="item-row">
                                <div class="item-left">
                                    <div class="item-title">@shift.Functie</div>
                                    <div class="item-meta">
                                        @shift.StartDateTime.ToString("ddd dd MMM HH:mm") – @shift.EindDateTime.ToString("HH:mm")
                                    </div>
                                    <div class="item-meta">@shift.WerkplekNaam</div>
                                </div>
                                <span class="badge @ShiftBadgeClass(shift.StartDateTime)">
                                    @ShiftLabel(shift.StartDateTime)
                                </span>
                            </div>
                        }
                    }
                </div>
            </section>

            <section class="card">
                <div class="overview-box">
                    <h2 class="card-title">Overzicht</h2>
                    <p class="card-sub">Een overzicht van jouw werk.</p>

                    @if (_isStudent)
                    {
                        <div class="stats-grid">
                            <div class="stat-card">
                                <div class="stat-label">Gewerkte uren</div>
                                <div class="stat-value">@FormatHours(_hoursOverview.GewerkteUren)</div>
                                <div class="stat-desc"></div>
                            </div>
                            <div class="stat-card">
                                <div class="stat-label">Geplande uren</div>
                                <div class="stat-value">@FormatHours(_hoursOverview.GeplandeUren)</div>
                                <div class="stat-desc"></div>
                            </div>
                            <div class="stat-card">
                                <div class="stat-label">Nog vrije uren</div>
                                <div class="stat-value">@FormatHours(_hoursOverview.OverigeUren)</div>
                                <div class="stat-desc"></div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="stats-grid">
                            <div class="stat-card">
                                <div class="stat-label">Verdiend</div>
                                <div class="stat-value">@FormatCurrency(TotalEarnedThisYear)</div>
                                <div class="stat-desc"></div>
                            </div>
                            <div class="stat-card">
                                <div class="stat-label">Volgende shift</div>
                                <div class="stat-value">@NextShiftLabel</div>
                                <div class="stat-desc"></div>
                            </div>
                            <div class="stat-card">
                                <div class="stat-label">Shifts deze maand</div>
                                <div class="stat-value">@ShiftsThisMonth</div>
                                <div class="stat-desc"></div>
                            </div>
                        </div>
                    }

                    <div class="tip-box">
                        Tip: hou het simpel. Plan je shifts, check je abonnementen, en werk naar je wishlist toe.
                    </div>
                </div>
            </section>

            <section class="card">
                <div class="card-header">
                    <div>
                        <h2 class="card-title">Abonnementen</h2>
                        <p class="card-sub">Jouw actieve abonnementen.</p>
                    </div>
                    <a class="btn-link" href="/abonnementen">Bekijk alles</a>
                </div>
                <div class="item-list">
                    @if (_subscriptions.Count == 0)
                    {
                        <div class="item-row">
                            <div class="item-meta">Geen abonnementen gevonden.</div>
                        </div>
                    }
                    else
                    {
                        @foreach (var sub in _subscriptions)
                        {
                            <div class="item-row">
                                <div class="item-left">
                                    <div class="item-title">@sub.Naam</div>
                                    <div class="item-meta">Vervalt: @sub.PeriodeEinde.ToString("dd MMM")</div>
                                </div>
                                <span class="badge">€ @sub.Prijs.ToString("0.00")</span>
                            </div>
                        }
                    }
                </div>
            </section>

            <section class="card card-fullwidth">
                <div class="card-header">
                    <div>
                        <h2 class="card-title">Wishlist</h2>
                        <p class="card-sub">Top 3 items waar je naartoe werkt.</p>
                    </div>
                    <a class="btn-link" href="/wishlist">Bekijk alles</a>
                </div>
                <div class="wish-grid">
                    @if (_wishlist.Count == 0)
                    {
                        <div class="wish-card">
                            <div class="wish-name empty-text">Geen items gevonden.</div>
                        </div>
                    }
                    else
                    {
                        @foreach (var item in _wishlist.Take(3))
                        {
                            <div class="wish-card">
                                <div class="wish-name">@item.ItemName</div>
                                <div class="wish-desc">@item.ItemDescription</div>
                                <div class="wish-footer">
                                    <span class="wish-tip">Prioriteit: @PriorityLabel(item.ItemPriority)</span>
                                </div>
                            </div>
                        }
                    }
                </div>
            </section>
        </main>
    </div>
}

@code {
    static readonly System.Globalization.CultureInfo NlBe = System.Globalization.CultureInfo.GetCultureInfo("nl-BE");

    bool _sessionChecked = false;
    bool _isLoggedIn = false;
    bool _isLoading = true;
    bool _isStudent;
    int _userId;
    string _fullName = "";
    List<ShiftDto> _allShifts = new();
    List<ShiftDto> _shifts = new();
    List<SubscriptionDto> _subscriptions = new();
    List<WishlistDto> _wishlist = new();
    HoursOverviewDto _hoursOverview = new();

    decimal TotalEarnedThisYear => Math.Round(
        _allShifts
            .Where(IsWorkedShiftThisYear)
            .Sum(s => NetHours(s) * (s.Uurloon ?? 0m)),
        2);

    int ShiftsThisMonth => _allShifts.Count(s =>
        s.StartDateTime.Year == DateTime.Today.Year &&
        s.StartDateTime.Month == DateTime.Today.Month);

    string NextShiftLabel
    {
        get
        {
            var nextShift = _allShifts
                .Where(s => s.StartDateTime > DateTime.Now)
                .OrderBy(s => s.StartDateTime)
                .FirstOrDefault();

            if (nextShift is null)
                return "Geen shift";

            var days = (nextShift.StartDateTime.Date - DateTime.Today).Days;

            return days switch
            {
                0 => "Vandaag",
                1 => "Morgen",
                _ => $"Over {days} dagen"
            };
        }
    }

    string NextShiftSubLabel
    {
        get
        {
            var nextShift = _allShifts
                .Where(s => s.StartDateTime > DateTime.Now)
                .OrderBy(s => s.StartDateTime)
                .FirstOrDefault();

            if (nextShift is null)
                return "Nog niets ingepland";

            return $"{nextShift.StartDateTime:ddd dd MMM HH:mm} · {nextShift.WerkplekNaam}";
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        try
        {
            var idResult = await SessionStorage.GetAsync<int>("userId");
            var nameResult = await SessionStorage.GetAsync<string>("userFullName");

            if (idResult.Success && idResult.Value > 0)
            {
                _userId = idResult.Value;
                _fullName = nameResult.Success ? nameResult.Value ?? "" : "";
                _isLoggedIn = true;
                _sessionChecked = true;
                await LoadData();
            }
            else
            {
                _isLoggedIn = false;
                _sessionChecked = true;
                StateHasChanged();
                Navigation.NavigateTo("/", forceLoad: false);
            }
        }
        catch
        {
            _isLoggedIn = false;
            _sessionChecked = true;
            Navigation.NavigateTo("/", forceLoad: false);
        }
    }

    async Task LoadData()
    {
        _isLoading = true;
        StateHasChanged();

        try
        {
            var userTask = Http.GetFromJsonAsync<UserDto>($"GetUserById?id={_userId}");
            var shiftsTask = Http.GetFromJsonAsync<List<ShiftDto>>($"GetAllShiftsFromUser?userId={_userId}");
            var subscriptionsTask = Http.GetFromJsonAsync<List<SubscriptionDto>>($"GetAllSubscriptionsFromUser?userId={_userId}");
            var wishlistTask = Http.GetFromJsonAsync<List<WishlistDto>>($"GetAllWishListItemsFromUser?userId={_userId}");

            await Task.WhenAll(userTask, shiftsTask, subscriptionsTask, wishlistTask);

            _isStudent = userTask.Result?.IsStudent ?? false;
            _allShifts = shiftsTask.Result ?? new();
            _shifts = _allShifts
                .Where(s => s.StartDateTime >= DateTime.Now)
                .OrderBy(s => s.StartDateTime)
                .Take(5)
                .ToList();
            _subscriptions = (subscriptionsTask.Result ?? new()).OrderBy(s => s.PeriodeEinde).ToList();
            _wishlist = (wishlistTask.Result ?? new()).Where(w => !w.ItemBought).OrderBy(w => w.ItemPriority).ToList();

            if (_isStudent)
            {
                _hoursOverview = await Http.GetFromJsonAsync<HoursOverviewDto>($"GetUserHoursOverview?userId={_userId}") ?? new();
            }
        }
        catch
        {
        }

        _isLoading = false;
        StateHasChanged();
    }

    static decimal NetHours(ShiftDto shift)
    {
        var hours = (decimal)(shift.EindDateTime - shift.StartDateTime).TotalHours - (shift.PauzeInMinuten / 60m);
        return hours < 0 ? 0 : Math.Round(hours, 2);
    }

    static bool IsWorkedShiftThisYear(ShiftDto shift)
    {
        var now = DateTime.Now;
        var startOfYear = new DateTime(now.Year, 1, 1, 0, 0, 0);
        var startOfNextYear = startOfYear.AddYears(1);

        return shift.EindDateTime <= now
            && shift.StartDateTime >= startOfYear
            && shift.StartDateTime < startOfNextYear;
    }

    static string FormatHours(decimal hours) => $"{hours:0.##}u";

    static string FormatCurrency(decimal amount) => amount.ToString("C", NlBe);

    static string ShiftLabel(DateTime start)
    {
        var diff = (start.Date - DateTime.Today).Days;
        return diff switch
        {
            0 => "Vandaag",
            1 => "Morgen",
            <= 7 => "Deze week",
            _ => "Volgende week"
        };
    }

    static string ShiftBadgeClass(DateTime start) => (start.Date - DateTime.Today).Days < 1 ? "badge badge-blue" : "badge badge-muted";

    static string PriorityLabel(int? prio) => prio switch
    {
        1 => "hoog",
        2 => "medium",
        3 => "laag",
        _ => "?"
    };

    record UserDto(string FirstName, string LastName, string Email, bool IsStudent);
    record HoursOverviewDto(int Jaar = 0, string? ResetDatum = null, decimal MaximumUren = 650, decimal GewerkteUren = 0, decimal GeplandeUren = 0, decimal OverigeUren = 0);
    record ShiftDto(int ShiftId, DateTime StartDateTime, DateTime EindDateTime, int PauzeInMinuten, string Functie, string? Opmerking, decimal? Uurloon, sbyte? Betaaldag, int AfdelingId, string WerkplekNaam);
    record SubscriptionDto(int AbonnementId, string Naam, decimal Prijs, DateOnly PeriodeStart, DateOnly PeriodeEinde, bool Betaald);
    record WishlistDto(int Idwishlist, string ItemName, decimal? ItemPrice, string? ItemDescription, string? ItemLink, int? ItemPriority, bool ItemBought);
}
