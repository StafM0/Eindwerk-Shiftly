@page "/"
@rendermode InteractiveServer
@inject HttpClient Http
@inject NavigationManager Navigation
@inject Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage.ProtectedSessionStorage SessionStorage

<PageTitle>Shiftly – Inloggen</PageTitle>

<div class="auth-root">
    <div class="auth-card @(IsRegister ? "flipped" : "")">

        <div class="panel panel-login">
            <h2 class="panel-title">Welkom terug</h2>
            <p class="panel-sub">Log in op je account om verder te gaan.</p>

            @if (!string.IsNullOrEmpty(_loginError))
            {
                <div class="alert-box">@_loginError</div>
            }

            <div class="field">
                <label>E-mailadres</label>
                <input type="email" placeholder="naam@voorbeeld.be"
                       @bind="_loginEmail" @bind:event="oninput" />
            </div>

            <div class="field">
                <label>Wachtwoord</label>
                <div class="pw-wrap">
                    <input type="@(_showLoginPw ? "text" : "password")" placeholder="••••••••"
                           @bind="_loginPassword" @bind:event="oninput" />
                    <button class="pw-toggle" type="button" @onclick="() => _showLoginPw = !_showLoginPw">
                        @(_showLoginPw ? "x" : "👁")
                    </button>
                </div>
            </div>

            <button class="btn-primary" @onclick="HandleLogin" disabled="@_isLoggingIn">
                @(_isLoggingIn ? "Bezig…" : "Inloggen")
            </button>

            <p class="switch-text">
                Nog geen account?
                <button class="link-btn" @onclick="() => SwitchTo(true)">Registreer je</button>
            </p>
        </div>

        <div class="panel panel-register">
            <h2 class="panel-title">Account aanmaken</h2>
            <p class="panel-sub">Maak je gratis account aan en begin vandaag.</p>

            @if (!string.IsNullOrEmpty(_registerError))
            {
                <div class="alert-box">@_registerError</div>
            }
            @if (!string.IsNullOrEmpty(_registerSuccess))
            {
                <div class="success-box">@_registerSuccess</div>
            }

            <div class="field-row">
                <div class="field">
                    <label>Voornaam</label>
                    <input type="text" placeholder="Jan" @bind="_regFirstName" @bind:event="oninput" />
                </div>
                <div class="field">
                    <label>Achternaam</label>
                    <input type="text" placeholder="Janssen" @bind="_regLastName" @bind:event="oninput" />
                </div>
            </div>

            <div class="field">
                <label>E-mailadres</label>
                <input type="email" placeholder="naam@voorbeeld.be" @bind="_regEmail" @bind:event="oninput" />
            </div>

            <div class="field">
                <label>Wachtwoord</label>
                <div class="pw-wrap">
                    <input type="@(_showRegPw ? "text" : "password")" placeholder="Minimaal 6 tekens"
                           @bind="_regPassword" @bind:event="oninput" />
                    <button class="pw-toggle" type="button" @onclick="() => _showRegPw = !_showRegPw">
                        @(_showRegPw ? "x" : "👁")
                    </button>
                </div>
            </div>

            <div class="field checkbox-field">
                <label class="checkbox-label">
                    <input type="checkbox" @bind="_regIsStudent" />
                    <span class="checkbox-custom"></span>
                    Ik ben student
                </label>
            </div>

            <button class="btn-primary" @onclick="HandleRegister" disabled="@_isRegistering">
                @(_isRegistering ? "Bezig…" : "Account aanmaken")
            </button>

            <p class="switch-text">
                Al een account?
                <button class="link-btn" @onclick="() => SwitchTo(false)">Inloggen</button>
            </p>
        </div>
    </div>
</div>

@code {
    // ── State ─────────────────────────────────────────────────────────────────
    private bool   IsRegister      = false;
    private bool   _showLoginPw    = false;
    private bool   _isLoggingIn    = false;
    private bool   _showRegPw      = false;
    private bool   _isRegistering  = false;
    private bool   _regIsStudent   = false;

    private string _loginEmail      = "";
    private string _loginPassword   = "";
    private string _loginError      = "";
    private string _regFirstName    = "";
    private string _regLastName     = "";
    private string _regEmail        = "";
    private string _regPassword     = "";
    private string _registerError   = "";
    private string _registerSuccess = "";

    // ── Helpers ───────────────────────────────────────────────────────────────

    private void SwitchTo(bool register)
    {
        IsRegister       = register;
        _loginError      = "";
        _registerError   = "";
        _registerSuccess = "";
    }

    // ── Login ─────────────────────────────────────────────────────────────────

    private async Task HandleLogin()
    {
        _loginError = "";

        if (string.IsNullOrWhiteSpace(_loginEmail) || string.IsNullOrWhiteSpace(_loginPassword))
        {
            _loginError = "Vul e-mailadres en wachtwoord in.";
            return;
        }

        _isLoggingIn = true;
        try
        {
            var url      = $"login?email={Uri.EscapeDataString(_loginEmail)}&password={Uri.EscapeDataString(_loginPassword)}";
            var response = await Http.GetAsync(url);

            if (response.IsSuccessStatusCode)
            {
                var user = await response.Content.ReadFromJsonAsync<LoginResponse>();
                if (user is not null)
                {
                    await SessionStorage.SetAsync("userId",        user.IdUser);
                    await SessionStorage.SetAsync("userFirstName", user.FirstNameUser);
                    await SessionStorage.SetAsync("userFullName",  $"{user.FirstNameUser} {user.NameUser}");
                }
                Navigation.NavigateTo("/dashboard");
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                _loginError = "Ongeldig e-mailadres of wachtwoord.";
            }
            else
            {
                _loginError = "Er is een fout opgetreden. Probeer het opnieuw.";
            }
        }
        catch
        {
            _loginError = "Kan geen verbinding maken met de server.";
        }
        finally
        {
            _isLoggingIn = false;
        }
    }

    // ── Register ──────────────────────────────────────────────────────────────

    private async Task HandleRegister()
    {
        _registerError   = "";
        _registerSuccess = "";

        if (string.IsNullOrWhiteSpace(_regFirstName) || string.IsNullOrWhiteSpace(_regLastName) ||
            string.IsNullOrWhiteSpace(_regEmail)     || string.IsNullOrWhiteSpace(_regPassword))
        {
            _registerError = "Vul alle velden in.";
            return;
        }

        if (_regPassword.Length < 6)
        {
            _registerError = "Wachtwoord moet minimaal 6 tekens bevatten.";
            return;
        }

        _isRegistering = true;
        try
        {
            var url = $"AddUser" +
                      $"?email={Uri.EscapeDataString(_regEmail)}" +
                      $"&firstName={Uri.EscapeDataString(_regFirstName)}" +
                      $"&name={Uri.EscapeDataString(_regLastName)}" +
                      $"&password={Uri.EscapeDataString(_regPassword)}" +
                      $"&isStudent={_regIsStudent.ToString().ToLower()}";

            var response = await Http.PostAsync(url, null);

            if (response.IsSuccessStatusCode)
            {
                _registerSuccess = "Account aangemaakt! Je kunt nu inloggen.";
                await Task.Delay(1500);
                _regFirstName = _regLastName = _regEmail = _regPassword = "";
                SwitchTo(false);
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Conflict)
            {
                _registerError = "Er bestaat al een account met dit e-mailadres.";
            }
            else
            {
                _registerError = "Er is een fout opgetreden. Probeer het opnieuw.";
            }
        }
        catch
        {
            _registerError = "Kan geen verbinding maken met de server.";
        }
        finally
        {
            _isRegistering = false;
        }
    }

    // ── DTOs ──────────────────────────────────────────────────────────────────

    private record LoginResponse(int IdUser, string NameUser, string FirstNameUser);
}
